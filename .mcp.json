{
  "mcpServers": {
    "atlassian": {
      "command": "py",
      "args": ["mcp-servers/jira_server.py"]
    },
    "gitlab": {
      "command": "py",
      "args": ["mcp-servers/gitlab_server.py"]
    },
    "aws": {
      "command": "py",
      "args": ["mcp-servers/aws_server.py"]
    },
    "jenkins": {
      "command": "py",
      "args": ["mcp-servers/jenkins_server.py"]
    },
    "sonarqube": {
      "command": "py",
      "args": ["mcp-servers/sonarqube_server.py"]
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "mcp-server-fetch"]
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer ${NOTION_TOKEN}\", \"Notion-Version\": \"2022-06-28\"}"
      }
    },
    "codebase": {
      "command": "py",
      "args": ["mcp-servers/codebase_indexer_server.py"]
    },
    "edgefabric-explain": {
      "command": "py",
      "args": ["mcp-servers/edgefabric_explain_server.py"]
    }
  }
}
