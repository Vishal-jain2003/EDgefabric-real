# ─────────────────────────────────────────────────────────────────
#  EdgeFabric MCP Servers — Environment Variables Template
#  Copy this to .env and fill in your credentials.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ─── SonarQube ───────────────────────────────────────────────────
SONAR_URL=https://your-sonar-instance/sonarqube
SONAR_TOKEN=your_sonar_token
SONAR_PROJECT_KEY=your_project_key

# ─── GitLab ──────────────────────────────────────────────────────
GITLAB_URL=https://your-gitlab-instance
GITLAB_TOKEN=your_gitlab_personal_access_token
GITLAB_PROJECT_ID=your_project_id

# ─── Jenkins ─────────────────────────────────────────────────────
JENKINS_URL=https://your-jenkins-instance/jenkins
JENKINS_USER=your_email@company.com
JENKINS_TOKEN=your_jenkins_api_token

# ─── Jira + Confluence ───────────────────────────────────────────
# For Jira Cloud: use https://yourorg.atlassian.net
# For Jira Server/DC: use your internal URL
JIRA_URL=https://your-jira-instance
# Jira API token (Cloud) or Personal Access Token (Server/DC)
JIRA_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=EF
# Confluence space key (visible in Confluence space settings)
CONFLUENCE_SPACE_KEY=EF

# ─── Notion ──────────────────────────────────────────────────────
NOTION_TOKEN=your_notion_integration_token
NOTION_DEFAULT_PARENT_PAGE_ID=your_default_parent_page_id

# ─── AWS ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=ap-south-1

# ─── EdgeFabric Observe API (for Explain server) ─────────────
OBSERVE_API_URL=http://localhost:8090
